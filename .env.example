# =============================================================================
# Rennes emploi dashboard — fichier d’exemple (copie vers .env : cp .env.example .env)
# =============================================================================
#
# --- Où sont les « ports » ? (hôte = ta machine, conteneur = in Docker)
#
# HOST_PORT          → URL du dashboard : http://127.0.0.1:<HOST_PORT>
# MAILPIT_UI_HOST_PORT → boîte mail locale (lire les mails de test) : http://127.0.0.1:<ce port>
# MAILPIT_SMTP_HOST_PORT → SMTP exposé sur l’hôte (utile si tu lances le backend Go hors Docker : SMTP 127.0.0.1:ce port)
# CAMOUFOX_HOST_PORT → UNIQUEMENT si tu lances « make up-full » : port pour joindre le scraper (sinon ignoré).
#   Défaut dans docker-compose : 18765 si tu ne mets rien dans .env.
#
# Les champs vides (FT_*, etc.) ne cassent pas le projet : sans identifiants FT, utilise MOCK_FT=true (défaut ci-dessous).
# =============================================================================

# --- Réseau / Docker : ports sur l’hôte (choisis des valeurs libres chez toi) ---
HOST_PORT=18443
# Optionnel : seulement utile avec make up-full (Camoufox). Sinon laisse absent ou 18765.
#CAMOUFOX_HOST_PORT=18765

AUTO_HOST_PORT=false
HOST_PORT_RANGE_START=18080
HOST_PORT_RANGE_END=18999

PORT=3000
DATA_DIR=./data

# --- Mail local (Mailpit) : « vrai » flux SMTP local + persistance + option relais vers ta boîte ---
#
# 1) Toujours actif : le dashboard parle en SMTP à Mailpit (mailpit:1025 dans Docker). C’est du vrai SMTP,
#    uniquement sur le réseau Docker — pas besoin de domaine ni de compte pour CAPTURER les messages.
# 2) Persistance : les messages restent après « docker compose down » (volume rennes-emploi-mailpit).
# 3) Option « comme un vrai mail » : remplis MAIL_FORWARD_TO + MAIL_RELAY_* pour qu’une COPIE parte vers
#    ton Gmail / autre via un relais SMTP (ex. mot de passe d’application Gmail, ou SMTP gratuit Brevo).
#    Laisses MAIL_FORWARD_TO vide = aucun envoi Internet, uniquement l’UI Mailpit.
#
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Rennes Emploi Dashboard <no-reply@localhost>"
MAILPIT_PUBLIC_URL=http://127.0.0.1:8025
MAILPIT_UI_HOST_PORT=8025
MAILPIT_SMTP_HOST_PORT=1025

# Relais optionnel (copie vers une vraie boîte). Exemple Gmail : MAIL_RELAY_HOST=smtp.gmail.com MAIL_RELAY_PORT=587
# + MAIL_RELAY_USER=toi@gmail.com MAIL_RELAY_PASS=<mot de passe d’application Google>
MAIL_FORWARD_TO=
MAIL_RELAY_HOST=
MAIL_RELAY_PORT=587
MAIL_RELAY_USER=
MAIL_RELAY_PASS=
MAIL_RELAY_STARTTLS=true
MAIL_RELAY_INSECURE=false

# --- France Travail (optionnel au début) ---
FT_CLIENT_ID=
FT_CLIENT_SECRET=
FT_OAUTH_SCOPE="api_evenementsv1 evenements"

FT_TOKEN_URL=https://entreprise.francetravail.fr/connexion/oauth2/access_token?realm=/partenaire
FT_API_BASE=https://api.francetravail.io/
FT_EVENTS_PATH=partenaire/evenements/v1/evenements

FT_FILTER_CODE_POSTAL=35000
FT_FILTER_DEPARTEMENT=35

FT_PORTAL_BASE_URL=https://mesevenementsemploi.francetravail.fr/mes-evenements-emploi

FT_USE_RANGE_HEADER=false
FT_RANGE_PAGE_SIZE=200

RENNES_LAT=48.1173
RENNES_LON=-1.6778
DEFAULT_RADIUS_KM=40

POLL_CRON=*/30 * * * *

# true = données fictives, pas besoin de FT_CLIENT_* (recommandé pour démarrer tout de suite)
MOCK_FT=true

FT_SEED_SILENT=true
STARTUP_POLL=true

UI_POLL_INTERVAL_MS=0

# --- Camoufox (scraping optionnel) — make up-full uniquement ---
#CAMOUFOX_SCRAPER_URL=http://camoufox-scraper:8765
#SCRAPER_TARGET_URL=https://exemple.org/page-avec-json-ld-event
SCRAPER_CACHE_TTL_SEC=300

# --- Backend Go sur l’hôte (sans Docker) avec Mailpit lancé via « make up » ---
#SMTP_HOST=127.0.0.1
#SMTP_PORT=1025
