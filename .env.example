# --- Réseau / Docker ---
# Si true, « make up » choisit un port libre dans la plage (évite les conflits locaux).
AUTO_HOST_PORT=true
HOST_PORT_RANGE_START=3080
HOST_PORT_RANGE_END=3200
# Port par défaut / préféré (utilisé tel quel si libre et AUTO_HOST_PORT=true)
HOST_PORT=3080

# Port HTTP dans le conteneur (ne pas changer sauf adaptation du Dockerfile)
PORT=3000

# Dossier données SQLite (dans Docker : /app/data)
DATA_DIR=./data

# --- France Travail : API « Mes évènements emploi » (OAuth2 client credentials) ---
# Ce n’est PAS « France Travail Connect » (voir README).
FT_CLIENT_ID=
FT_CLIENT_SECRET=
# Scope exact affiché sur francetravail.io pour ton application (souvent lié à l’API événements).
FT_OAUTH_SCOPE="api_evenementsv1 evenements"

FT_TOKEN_URL=https://entreprise.francetravail.fr/connexion/oauth2/access_token?realm=/partenaire
FT_API_BASE=https://api.francetravail.io/
# Chemin relatif après la base (sans slash initial). À vérifier dans la doc du produit sur francetravail.io si 404.
FT_EVENTS_PATH=partenaire/evenements/v1/evenements
# Optionnel : suffixe de requête (sans ? initial), si la doc FT l’exige
# FT_EXTRA_QUERY=

# Filtres géographiques envoyés à l’API (si supportés par ta version du produit — voir doc OpenAPI francetravail.io)
FT_FILTER_CODE_POSTAL=35000
FT_FILTER_DEPARTEMENT=35

# Portail public (même univers que l’API « Mes évènements emploi ») — liens de repli / démo
FT_PORTAL_BASE_URL=https://mesevenementsemploi.francetravail.fr/mes-evenements-emploi
# Modèle d’URL détail si la doc l’indique, ex. : {portal}/chemin/{id}
# FT_PORTAL_EVENT_URL_TEMPLATE=

# Pagination : beaucoup d’API France Travail utilisent l’en-tête HTTP Range. Active seulement si la doc du produit le prévoit (sinon 416).
FT_USE_RANGE_HEADER=false
FT_RANGE_PAGE_SIZE=200

# Centre Rennes + rayon km (périphérie)
RENNES_LAT=48.1173
RENNES_LON=-1.6778
DEFAULT_RADIUS_KM=40

# Polling nouveaux événements (cron)
POLL_CRON=*/30 * * * *

# Mode démo sans appels FT (données fictives pour tester l’UI / emails)
MOCK_FT=false

# Premier poll : enregistre les événements existants sans envoyer d’emails (recommandé)
FT_SEED_SILENT=true
# Lancer un poll 3 s après le démarrage
STARTUP_POLL=true

# Rafraîchissement automatique du dashboard dans le navigateur (ms). 0 = désactivé.
UI_POLL_INTERVAL_MS=0

# --- SMTP (notifications) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Rennes Emploi Dashboard <no-reply@localhost>"

# --- Camoufox (scraping optionnel, JSON-LD Event) — lancer : make up-full ---
# Décommente les deux lignes ci-dessous seulement si tu utilises make up-full (sinon le dashboard tenterait d’appeler un hôte inexistant).
#CAMOUFOX_SCRAPER_URL=http://camoufox-scraper:8765
#SCRAPER_TARGET_URL=https://exemple.org/page-avec-json-ld-event
# Port publié sur la machine pour le scraper (health : /health)
CAMOUFOX_HOST_PORT=8765
# Cache côté dashboard (secondes) entre deux appels au scraper
SCRAPER_CACHE_TTL_SEC=300
